{% extends 'layouts/base.twig' %}

{% block title %}Список книг - Библиотека{% endblock %}

{% block content %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="page-title">
            <i class="bi bi-book"></i> Каталог книг
        </h1>
        <span class="badge bg-primary rounded-pill p-3">
            Всего книг: {{ books|length }}
        </span>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="text-muted mb-0">
                Добро пожаловать, <span class="fw-normal">Админ!</span>
        </h5>
    </div>

    <div class="table-responsive">
        <table class="custom-table">
            <thead>
            <tr class="table-header">
                <td><i class="bi bi-bookmark"></i> Название</td>
                <td><i class="bi bi-person"></i> Автор</td>
                <td><i class="bi bi-check-circle"></i> Наличие</td>
                <td><i class="bi bi-clock-history"></i> История</td>
                <td colspan="2"><i class="bi bi-gear"></i> Действия</td>
            </tr>
            </thead>
            <tbody>
            {% for book in books %}
                <tr>
                    <td><strong>{{ book.book_name }}</strong></td>
                    <td>{{ book.author_name }}</td>
                    <td>
                        {% if book.available %}
                            <span class="status-badge status-available">
                                    <i class="bi bi-check-circle"></i> В наличии
                                </span>
                        {% else %}
                            <span class="status-badge status-unavailable">
                                    <i class="bi bi-x-circle"></i> Нет в наличии
                                </span>
                        {% endif %}
                    </td>
                    <td>
                        <a href="/admin/books/{{ book.id }}" class="btn btn-outline-primary btn-action">
                            <i class="bi bi-clock-history"></i> История
                        </a>
                    </td>
                    <td class="clear">
                        <a href="/admin/books/update/{{ book.id }}" class="btn btn-warning btn-action">
                            <i class="bi bi-pencil"></i> Ред.
                        </a>
                    </td>
                    <td class="clear">
                        <a href="/admin/books/delete/{{ book.id }}" class="btn btn-danger btn-action"
                           onclick="return confirm('Вы уверены, что хотите удалить эту книгу?')">
                            <i class="bi bi-trash"></i> Уд.
                        </a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="text-center py-5">
                        <i class="bi bi-emoji-frown" style="font-size: 3rem;"></i>
                        <p class="mt-3">Книг пока нет</p>
                    </td>
                </tr>
            {% endfor %}
            <tr>
                <td class="clear pt-4" colspan="6">
                    <a href="/admin/books/create" class="btn btn-success btn-action">
                        <i class="bi bi-plus-circle"></i> Добавить новую книгу
                    </a>
                </td>
            </tr>
            </tbody>
        </table>
    </div>
{% endblock %}